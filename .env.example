# PostgreSQL Configuration (Sandbox Database)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=ciphersql_sandbox

# MongoDB Configuration (Persistence DB)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ciphersqlstudio?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxxxxxxxxx
# or for Gemini
GEMINI_API_KEY=xxxxxxxxxxxx

# Security
JWT_SECRET=your_jwt_secret_key
QUERY_TIMEOUT=5000
